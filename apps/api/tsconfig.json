{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // NestJS DI reads `design:paramtypes` metadata, which requires class param types to remain
    // VALUE imports. verbatimModuleSyntax elides them → metadata becomes `Function` and DI fails at
    // runtime. Off for the Nest app (standard Nest setup); pure packages keep it on.
    "verbatimModuleSyntax": false
  },
  "references": [
    { "path": "../../packages/domain" },
    { "path": "../../packages/config" },
    { "path": "../../packages/authz" },
    { "path": "../../packages/adapter-contracts" },
    { "path": "../../packages/db" },
    { "path": "../../adapters/auth-local" }
  ],
  "include": ["src/**/*"]
}
