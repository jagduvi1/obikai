{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // NestJS DI reads `design:paramtypes` metadata, which requires class param types to remain
    // VALUE imports. verbatimModuleSyntax elides them → metadata becomes `Function` and DI fails at
    // runtime. Off for the Nest app (standard Nest setup); pure packages keep it on.
    "verbatimModuleSyntax": false,
    // Relaxed for the app/DTO tier: zod `.partial()` yields `{ x?: T | undefined }`, which is the
    // natural shape for PATCH bodies (repos drop undefined). The pure packages (domain, rank-engine,
    // billing math) keep exactOptionalPropertyTypes ON where it actually prevents bugs.
    "exactOptionalPropertyTypes": false
  },
  "references": [
    { "path": "../../packages/domain" },
    { "path": "../../packages/config" },
    { "path": "../../packages/authz" },
    { "path": "../../packages/billing" },
    { "path": "../../packages/adapter-contracts" },
    { "path": "../../packages/db" },
    { "path": "../../packages/rank-engine" },
    { "path": "../../packages/i18n" },
    { "path": "../../adapters/auth-local" },
    { "path": "../../adapters/email-smtp" }
  ],
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
