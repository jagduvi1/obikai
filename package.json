{
  "name": "obikai",
  "version": "0.0.0",
  "private": true,
  "description": "Obikai — dojo-native, open-source (AGPLv3) SaaS for martial-arts schools. Multi-tenant hosted + single-tenant self-host from one codebase.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "boundaries": "eslint .",
    "test": "turbo run test",
    "test:pure": "pnpm --filter \"./packages/**\" run test",
    "license:check": "node scripts/license-check.mjs",
    "verify:purity": "node scripts/assert-rank-engine-purity.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "turbo": "^2.3.3",
    "typescript": "catalog:"
  },
  "pnpm": {
    "comment": "overrides: security pins for transitive deps (Dependabot/Trivy); drop once upstreams ship fixes",
    "overrides": {
      "handlebars@<4.7.9": "^4.7.9",
      "multer@<2.1.1": "^2.1.1"
    }
  }
}
