# ─────────────────────────────────────────────────────────────────────────────
# Obikai configuration. Copy to `.env` and adjust. All config is env-driven
# (ADR-0009); no secrets in the repo. Defaults below are the self-hostable,
# no-lock-in, AI-OFF choices — a fresh self-host boots with only the mandatory
# services (app + MongoDB + Redis) plus the operator's own SMTP and S3 endpoint.
# Validated at boot by @obikai/config (zod) — the app refuses to start on a bad value.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deploy model (two-axis — ADR-0002) ───────────────────────────────────────
# DEPLOY_MODE:  self-host (default) | hosted
# TENANCY:      single (default)    | multi
# Self-host defaults to single-tenant but is federation-CAPABLE: set TENANCY=multi
# to host several clubs (an association) from one instance — no code fork.
DEPLOY_MODE=self-host
TENANCY=single

# Base domain. Self-host: the single domain the app is served on.
# Hosted: the apex under which tenants get <slug>.<BASE_DOMAIN> subdomains.
BASE_DOMAIN=localhost
# Required when DEPLOY_MODE=self-host: the slug of the single auto-provisioned tenant.
SELF_HOST_TENANT_SLUG=mydojo
# Number of trusted proxy hops (Traefik) for correct X-Forwarded-* handling.
TRUST_PROXY_HOPS=1

# ── Mandatory infrastructure ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/obikai
REDIS_URL=redis://redis:6379
# In self-host, run BullMQ jobs inside the api process (no separate worker container).
RUN_WORKER_IN_PROCESS=true

# ── Secrets ───────────────────────────────────────────────────────────────────
# YOU MUST REPLACE THESE. The app refuses to boot with a placeholder value (these "change-me…"
# strings fail validation by design) so a real deployment can never ship a publicly-known key.
# Access-token signing key. Generate: openssl rand -hex 64
AUTH_JWT_SECRET=change-me-to-a-strong-random-string
# Master key wrapping per-subject data-encryption keys for GDPR crypto-shred (ADR-0007).
# Generate: openssl rand -hex 32
DATA_MASTER_KEY=change-me-to-a-32-byte-hex-key

# ── Storage adapter (ADR-0003) — default: S3-compatible (MinIO/AWS/R2/Scaleway) ─
# STORAGE_PROVIDER: s3 (default) | fs   (fs = local filesystem, true single-box self-host)
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=eu-north-1
S3_BUCKET=obikai
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# HOSTED mode keeps member data in the EU/EEA: S3_REGION must be an EU/EEA region (Arts. 44–49).
# Set to true ONLY to deliberately allow a non-EU region (audited escape hatch). Self-host is exempt.
ALLOW_NON_EU_RESIDENCY=false
# For STORAGE_PROVIDER=fs:
FS_STORAGE_ROOT=/data/storage

# ── Email adapter (ADR-0003) — default: SMTP (point at your own server) ────────
# EMAIL_PROVIDER: smtp (default) | ses | postmark
EMAIL_PROVIDER=smtp
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Obikai <no-reply@localhost>

# ── SMS adapter (ADR-0003) — default: disabled (optional, never required) ──────
# SMS_PROVIDER: disabled (default) | elks | twilio
SMS_PROVIDER=disabled

# ── Auth adapter (ADR-0004) — default: local (self-hostable, OIDC optional) ────
# AUTH_PROVIDER: local (default) | oidc
AUTH_PROVIDER=local
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# OIDC is optional federation — leave blank unless AUTH_PROVIDER=oidc.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Payments adapter (ADR-0006) — default: manual (cash/bank transfer) ─────────
# PAYMENT_PROVIDER: manual (default, self-host) | stub | stripe | swish | autogiro | vipps-mobilepay
# 'manual' lets staff mark invoices paid (cash/bank transfer) — fully functional with NO PSP.
# Real recurring rails require contracting a PSP (human-owned decision).
PAYMENT_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI adapter (ADR-0005) — default: none (product is fully functional AI-OFF) ─
# AI_PROVIDER: none (default) | ollama | anthropic | openai
# AI only AUTHORS config/content and ASSISTS people; it is NEVER in the rank-decision path.
# If you enable an EXTERNAL provider, member-PII tasks still route to a local model unless
# a per-tenant DPA/consent flag is set (ADR-0005). Prefer 'ollama' for local, GDPR-safe AI.
AI_PROVIDER=none
OLLAMA_BASE_URL=http://ollama:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── VAT-number validation (ADR-0025) — default: none (offline format check only) ─
# VAT_VALIDATION_PROVIDER: none (default; existence not checked) | vies (EU VIES REST).
# Offline VAT FORMAT validation always runs regardless. Enable 'vies' for the authoritative
# registration check (needed for intra-EU B2B reverse charge). VIES is free + needs no key, but
# is rate-limited and routinely returns transient "unavailable" — never treated as "invalid".
VAT_VALIDATION_PROVIDER=none
# VIES_BASE_URL=https://ec.europa.eu/taxation_customs/vies/rest-api/check-vat-number

# ── First-run bootstrap ───────────────────────────────────────────────────────
# Create the first owner without email. NOTE: automatic SEED_ON_START at boot is NOT wired yet —
# for now run the CLI: `obikai create-owner` (uses BOOTSTRAP_OWNER_EMAIL / _PASSWORD if set).
SEED_ON_START=false
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_PASSWORD=

# ── Production images (docker-compose.prod.yml) ───────────────────────────────-
# Pulls ${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/obikai-{api,worker}:${VERSION} — matching what
# release.yml publishes. Override the namespace to use your own registry/fork; pin VERSION to a release.
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=jagduvi1
VERSION=latest

# ── Telemetry (opt-in only — OSS community expectation) ────────────────────────
TELEMETRY_ENABLED=false
