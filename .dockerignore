# Keep the Docker build context lean and deterministic. The image is built from
# the committed source + lockfile only; never copy in local install/build state.

# Dependencies (re-installed in the deps stage from the lockfile)
**/node_modules
.pnpm-store

# Build output (re-built in the build stage)
**/dist
**/*.tsbuildinfo
.turbo

# VCS & CI metadata
.git
.github
.gitignore

# Env & secrets — NEVER ship into an image (ADR-0009). Pass via env_file at runtime.
.env
.env.*
!.env.example

# Tests / coverage / local data
coverage
.data

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Docs (not needed at build time)
docs
